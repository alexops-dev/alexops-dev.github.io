---
import { projects } from '../data/projects';
---

<section id="projects">
  <div class="container">
    <span class="eyebrow">Projects</span>
    <h2>Selected Projects</h2>
    <p style="margin-bottom: 32px; max-width: 760px;">
      A curated set of public projects across cloud-native engineering, embedded systems,
      backend development, and applied software architecture.
    </p>

    <div class="grid grid-2">
      {projects.map((project) => (
        <article class="card project-card">
          <div class="project-card-top">
            <h3>{project.title}</h3>
            {project.featured && <span class="project-badge">Featured</span>}
          </div>

          <p>{project.description}</p>

          <div class="project-tags">
            {project.stack.map((item) => (
              <span class="project-tag">{item}</span>
            ))}
          </div>

          <div class="project-links">
            <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="button secondary">
              View on GitHub
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>