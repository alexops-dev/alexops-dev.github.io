---
import { projects } from '../data/projects';
---

<section id="projects">
  <div class="container">
    <span class="eyebrow">Projects</span>
    <h2>Selected Projects</h2>
    <p style="margin-bottom: 32px; max-width: 760px;">
      A curated set of public projects across cloud-native engineering, embedded systems,
      backend development, and applied software architecture.
    </p>

    <div class="grid grid-2">
      {projects.map((project) => (
        <article class="card project-card">
          <div class="project-card-top">
            <h3>{project.title}</h3>
            {project.featured && <span class="project-badge">Featured</span>}
          </div>

          <p>{project.description}</p>
        
        <div class="project-card-bottom">
          <div class="project-tags">
            {project.stack.map((item) => (
              <span class="project-tag">{item}</span>
            ))}
          </div>

          <div class="project-links">
            <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="button secondary github-button">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 .5C5.65.5.75 5.4.75 11.75c0 5.08 3.29 9.38 7.85 10.9.57.1.78-.25.78-.55
                0-.27-.01-1.16-.02-2.1-3.19.69-3.87-1.54-3.87-1.54-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.71.08-.71
                1.16.08 1.77 1.2 1.77 1.2 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.64
                0-1.25.45-2.27 1.19-3.07-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.18 1.17a11.1 11.1 0 0 1 5.8 0
                c2.2-1.48 3.17-1.17 3.17-1.17.63 1.58.23 2.75.11 3.04.74.8 1.19 1.82 1.19 3.07
                0 4.38-2.69 5.34-5.25 5.63.41.35.78 1.04.78 2.1 0 1.52-.01 2.75-.01 3.13
                0 .3.2.66.79.55 4.55-1.52 7.83-5.82 7.83-10.9C23.25 5.4 18.35.5 12 .5z"/>
              </svg>

              <span>View on GitHub</span>
            </a>
          </div>
        </div>
        </article>
      ))}
    </div>
  </div>
</section>